# ==============================
# 鸣镝系统 环境变量示例
# 复制为 .env 后修改
# ==============================

# ==== 对外端口 ====
API_PORT=8000
UDP_PORT=5005
REDIS_PORT=6379
MQTT_PORT=1883
INFLUXDB_PORT=8086

# ==== InfluxDB ====
INFLUXDB_USER=admin
INFLUXDB_PASSWORD=admin123456
INFLUXDB_ORG=mingdi-lab
INFLUXDB_BUCKET=mingdi
INFLUXDB_TOKEN=mingdi-super-secret-admin-token-v2

# ==== 告警阈值 ====
ALERT_FREQ_MIN=800
ALERT_FREQ_MAX=3500
ALERT_RANGE_MIN=150
ALERT_SPL_MIN=55
